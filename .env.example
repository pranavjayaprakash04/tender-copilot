# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/tendercopilot

# Groq (free at console.groq.com — no credit card)
GROQ_API_KEY=gsk_your-groq-api-key

# Redis (free at upstash.com)
REDIS_URL=redis://localhost:6379

# WhatsApp Cloud API (Meta Developer Portal — free)
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_APP_SECRET=your-app-secret

# Resend (free at resend.com)
RESEND_API_KEY=re_your-resend-api-key

# Razorpay (test keys are free)
RAZORPAY_KEY_ID=rzp_test_your-key-id
RAZORPAY_KEY_SECRET=your-secret-key

# App
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ENVIRONMENT=development
LOG_LEVEL=INFO